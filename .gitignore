# Binary
/aurex
/aurex.exe
aurex-linux-*
aurex-darwin-*
aurex-windows-*.exe

# Runtime state — secrets, ephemeral, never commit
/aurex.config.json
/aurex.cert.pem
/aurex.key.pem
/aurex.ts.cert.pem
/aurex.ts.key.pem
/aurex.subscriptions.json
/aurex.log

# Node
/client/node_modules/

# Frontend build output is regenerated by `npm run build` and embedded by
# `go build`. Don't track it, but keep the directory present so `go:embed`
# can find it at build time.
/client/dist/*
!/client/dist/.gitkeep

# Editor cruft
*.swp
.DS_Store
